# Copy to .env for docker-compose usage.
# Set this to the official Isaac Lab / Isaac Sim image tag you can pull locally.
# The validated default here is an example, not a promise that every account can access it.
ISAACLAB_BASE_IMAGE=nvcr.io/nvidia/isaac-lab:2.3.0
HAC_IMAGE_NAME=human-ai-collab:latest

# Required: higher-level LLM key used by the commander path.
COMMANDER_API_KEY=
COMMANDER_LLM_MODEL=gemini-2.5-flash

# Optional Cosmos observer / VLM endpoint.
COSMOS_BASE_URL=
COSMOS_CHAT_COMPLETIONS_URL=
COSMOS_MODEL=/models/Cosmos-Reason2-8B
COSMOS_API_KEY=
COSMOS_TIMEOUT=60

# Optional long-term memory backend.
MEM0_API_KEY=

# Runtime toggles.
CUDA_VISIBLE_DEVICES=0
HAC_PREFER_LOCAL_SCENE_ASSETS=1
HAC_AUTO_DOWNLOAD_SCENE_ASSETS=0
HAC_ENABLE_ROOM_SHELL_FALLBACK=0

# GUI / container runtime.
DISPLAY=:0
# Absolute host path to the Xauthority file for the desktop session running X11.
# Prefer the current value of: echo $XAUTHORITY
# Example: /run/user/1000/gdm/Xauthority
XAUTHORITY_HOST_PATH=
ACCEPT_EULA=Y
PRIVACY_CONSENT=Y
OMNI_KIT_ACCEPT_EULA=Y
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=all
ISAACLAB_ROOT=/isaac-sim
# Usually auto-detected by docker/entrypoint.sh. Override only if your image differs.
ISAACLAB_LAUNCHER=
